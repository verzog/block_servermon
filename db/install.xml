<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="blocks/servermon/db" VERSION="20260329" COMMENT="XMLDB file for block_servermon"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="block_servermon_log" COMMENT="Historical server metric snapshots logged every 5 minutes">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Unix timestamp of snapshot"/>
        <FIELD NAME="cpu_cores" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="0" COMMENT="Number of CPU cores detected"/>
        <FIELD NAME="cpu_percore" TYPE="text" NOTNULL="false" COMMENT="JSON array of per-core CPU percentages"/>
        <FIELD NAME="ram_pct" TYPE="number" LENGTH="5" DECIMALS="1" NOTNULL="false" COMMENT="RAM usage percentage"/>
        <FIELD NAME="disk_pct" TYPE="number" LENGTH="5" DECIMALS="1" NOTNULL="false" COMMENT="Disk usage percentage"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="timecreated" UNIQUE="false" FIELDS="timecreated" COMMENT="For efficient time-range queries and cleanup"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
